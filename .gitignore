# === Track A round-trip evidence (heavy, operator-private, regenerated) ===
# Snapshot trees from real-stand round-trips (Track A / Step 6).
examples/demo-dumps/_snapshots/
# Live in-progress dump trees regenerated by /DumpConfigToFiles. Not
# authored repo content. The dump_path is operator-specific anyway.
examples/demo-dumps/infobase6/

# === Audit history (operator-private, append-only) ===
**/.audit/

# === Runtime state (Phase 6 / Step 6 runtime hardening — regenerated) ===
.runtime/
**/.runtime/

# === Bootstrap work directories (runtime state holders) ===
examples/demo-infobase/_work/

# === Local-only writable / fixed configs ===
# By Track A convention these live under %TEMP% with cleartext
# DESIGNER credentials. These patterns guard the repo against an
# accidental copy landing in the working tree.
*-writable.config.json
*.config.fixed.json
*.config.json.bak

# === Local helper / scratch directories ===
scratch/
.scratch/
